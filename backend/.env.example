# Excel Agent Backend - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=32000
TEMPERATURE=0.0

# ============================================================================
# Agent Configuration
# ============================================================================
MAX_ITERATIONS=100
MAX_CONTEXT_MESSAGES=50
MAX_RESULT_ROWS_FOR_LLM=500

# ============================================================================
# Advanced Features
# ============================================================================
ENABLE_ADVANCED_STATS=true
STATS_CONFIDENCE_LEVEL=0.95
SESSION_PERSISTENCE_ENABLED=true
SESSION_CACHE_DIR=./session_cache

# ============================================================================
# File Processing
# ============================================================================
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# ============================================================================
# Redis (optional - for production session storage)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ============================================================================
# Database (optional)
# ============================================================================
DATABASE_URL=

# ============================================================================
# Azure (optional - for Azure OpenAI or storage)
# ============================================================================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
BACKEND_URL=http://localhost:8000

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173
